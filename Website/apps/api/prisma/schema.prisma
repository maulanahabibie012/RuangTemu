generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ATTENDEE
  ORGANIZER
  ADMIN
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  passwordHash         String   @map("password_hash")
  name                 String
  role                 Role     @default(ATTENDEE)
  avatarUrl            String?  @map("avatar_url")
  refreshToken         String?  @map("refresh_token")
  emailVerified        Boolean  @default(false) @map("email_verified")
  otpHash              String?  @map("otp_hash")
  otpExpiresAt         DateTime? @map("otp_expires_at")
  resetTokenHash       String?  @map("reset_token_hash")
  resetTokenExpiresAt  DateTime? @map("reset_token_expires_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  events               Event[]  @relation("OrganizerEvents")

  @@map("users")
}

enum TicketType {
  FREE
  PAID
}

enum EventStatus {
  DRAFT
  ACTIVE
  FULL
  CANCELLED
  COMPLETED
}

enum EventCategory {
  TECHNOLOGY
  MUSIC
  SPORTS
  EDUCATION
  BUSINESS
  ART
  FOOD
  HEALTH
  SOCIAL
  OTHER
}

model Event {
  id              String        @id @default(uuid())
  organizerId     String        @map("organizer_id")
  title           String
  description     String
  category        EventCategory @default(OTHER)
  coverImageUrl   String?       @map("cover_image_url")
  locationName    String        @map("location_name")
  locationLat     Float?        @map("location_lat")
  locationLng     Float?        @map("location_lng")
  eventDate       DateTime      @map("event_date")
  eventEndDate    DateTime?     @map("event_end_date")
  maxCapacity     Int           @map("max_capacity")
  currentCount    Int           @default(0) @map("current_count")
  ticketType      TicketType    @default(FREE) @map("ticket_type")
  ticketPrice     Int           @default(0) @map("ticket_price")
  status          EventStatus   @default(DRAFT)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organizer       User          @relation("OrganizerEvents", fields: [organizerId], references: [id])

  @@index([category])
  @@index([status])
  @@index([eventDate])
  @@index([organizerId])
  @@map("events")
}
