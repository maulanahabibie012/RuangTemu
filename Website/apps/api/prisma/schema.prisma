generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ATTENDEE
  ORGANIZER
  ADMIN
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  passwordHash         String   @map("password_hash")
  name                 String
  role                 Role     @default(ATTENDEE)
  avatarUrl            String?  @map("avatar_url")
  refreshToken         String?  @map("refresh_token")
  emailVerified        Boolean  @default(false) @map("email_verified")
  otpHash              String?  @map("otp_hash")
  otpExpiresAt         DateTime? @map("otp_expires_at")
  resetTokenHash       String?  @map("reset_token_hash")
  resetTokenExpiresAt  DateTime? @map("reset_token_expires_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  events               Event[]  @relation("OrganizerEvents")
  registrations        Registration[] @relation("UserRegistrations")

  @@map("users")
}

enum TicketType {
  FREE
  PAID
}

enum EventStatus {
  DRAFT
  ACTIVE
  FULL
  CANCELLED
  COMPLETED
}

enum EventCategory {
  TECHNOLOGY
  MUSIC
  SPORTS
  EDUCATION
  BUSINESS
  ART
  FOOD
  HEALTH
  SOCIAL
  OTHER
}

model Event {
  id              String        @id @default(uuid())
  organizerId     String        @map("organizer_id")
  title           String
  description     String
  category        EventCategory @default(OTHER)
  coverImageUrl   String?       @map("cover_image_url")
  locationName    String        @map("location_name")
  locationLat     Float?        @map("location_lat")
  locationLng     Float?        @map("location_lng")
  eventDate       DateTime      @map("event_date")
  eventEndDate    DateTime?     @map("event_end_date")
  maxCapacity     Int           @map("max_capacity")
  currentCount    Int           @default(0) @map("current_count")
  ticketType      TicketType    @default(FREE) @map("ticket_type")
  ticketPrice     Int           @default(0) @map("ticket_price")
  status          EventStatus   @default(DRAFT)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organizer       User          @relation("OrganizerEvents", fields: [organizerId], references: [id])
  registrations   Registration[] @relation("EventRegistrations")

  @@index([category])
  @@index([status])
  @@index([eventDate])
  @@index([organizerId])
  @@map("events")
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Registration {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  eventId         String             @map("event_id")
  status          RegistrationStatus @default(PENDING)
  paymentStatus   PaymentStatus      @default(UNPAID) @map("payment_status")
  qrCode          String?            @map("qr_code")
  heldUntil       DateTime?          @map("held_until")
  checkedInAt     DateTime?          @map("checked_in_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user            User               @relation("UserRegistrations", fields: [userId], references: [id])
  event           Event              @relation("EventRegistrations", fields: [eventId], references: [id])
  payment         Payment?           @relation("RegistrationPayment")

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@map("registrations")
}

enum PaymentMethod {
  MIDTRANS
  MANUAL
}

model Payment {
  id              String        @id @default(uuid())
  registrationId  String        @unique @map("registration_id")
  amount          Int
  platformFee     Int           @default(0) @map("platform_fee")
  method          PaymentMethod @default(MIDTRANS)
  externalId      String?       @map("external_id")
  snapToken       String?       @map("snap_token")
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  registration    Registration  @relation("RegistrationPayment", fields: [registrationId], references: [id])

  @@index([externalId])
  @@index([status])
  @@map("payments")
}
